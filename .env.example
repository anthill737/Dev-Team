# Dev Team backend environment — all variables are optional; defaults in app/config.py

# Persist your Anthropic API key so you aren't prompted in the UI every time.
# If set, the backend loads this on startup and the frontend skips the key-entry form.
# If omitted, the normal UI prompt appears.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxx

# Logging
# DEVTEAM_LOG_LEVEL=INFO

# Where to persist the project registry (list of known projects)
# DEVTEAM_PROJECTS_REGISTRY_PATH=/data/projects.json

# Default model assignments per agent role. Override if you want to economize
# or if the default model strings drift.
# DEVTEAM_MODEL_ARCHITECT=claude-opus-4-7
# DEVTEAM_MODEL_DISPATCHER=claude-sonnet-4-6
# DEVTEAM_MODEL_CODER=claude-sonnet-4-6
# DEVTEAM_MODEL_REVIEWER=claude-opus-4-7

# Default budgets — users can override per-project during setup
# DEVTEAM_DEFAULT_TASK_TOKEN_BUDGET=50000
# DEVTEAM_DEFAULT_PROJECT_TOKEN_BUDGET=2000000
# DEVTEAM_DEFAULT_MAX_TASK_ITERATIONS=5
