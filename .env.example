# Dev Team backend environment — all variables are optional; defaults in app/config.py

# ── Agent runner ──────────────────────────────────────────────────────────────
# Which backend powers agent invocations. Two modes:
#
#   claude_code (default): use the user's Claude Code CLI subscription.
#     Auth comes from `~/.claude` (run `claude` once to log in, or
#     `claude setup-token` for an OAuth token). No per-token billing —
#     usage counts against Pro/Max quota. Each agent call spawns a
#     `claude` subprocess (~2-3s cold start).
#
#   api: use direct Anthropic API calls with an API key (below). Pay-per-token.
#     ANTHROPIC_API_KEY required.
#
# DEVTEAM_RUNNER=claude_code

# ── API key (only used when DEVTEAM_RUNNER=api) ───────────────────────────────
# Persist your Anthropic API key so you aren't prompted in the UI every time.
# Ignored entirely in claude_code mode (the default) — auth comes from the
# `claude` CLI subscription instead.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxx

# ── Logging ───────────────────────────────────────────────────────────────────
# DEVTEAM_LOG_LEVEL=INFO

# ── Project registry path ─────────────────────────────────────────────────────
# Where to persist the list of known projects.
# DEVTEAM_PROJECTS_REGISTRY_PATH=/data/projects.json

# ── Model assignments per agent role ──────────────────────────────────────────
# Override if you want to economize or if model strings drift.
# DEVTEAM_MODEL_ARCHITECT=claude-sonnet-4-6
# DEVTEAM_MODEL_DISPATCHER=claude-sonnet-4-6
# DEVTEAM_MODEL_CODER=claude-sonnet-4-6
# DEVTEAM_MODEL_REVIEWER=claude-opus-4-7

# ── Default budgets ───────────────────────────────────────────────────────────
# Users can override per-project at create time.
# DEVTEAM_DEFAULT_TASK_TOKEN_BUDGET=150000
# DEVTEAM_DEFAULT_PROJECT_TOKEN_BUDGET=5000000
# DEVTEAM_DEFAULT_MAX_TASK_ITERATIONS=8
